---
import BaseLayout from '../layouts/BaseLayout.astro';
import TerminalCard from '../components/TerminalCard.astro';

const stats = [
  { value: '15+', label: 'Years experience' },
  { value: '100s', label: 'Companies supported across the U.S.' },
  { value: '22', label: 'Custom automation tools built' },
  { value: '124K', label: 'Endpoints migrated' },
];

const capabilities = [
  {
    route: '$ /full-stack',
    title: 'Full-Stack Development',
    description:
      'Web applications and APIs from the database up, with clean architecture, code reviews, and CI/CD as standard practice.',
    bullets: [
      'JavaScript/TypeScript, PHP, Python, React',
      'RESTful APIs & NestJS microservices',
      'AWS: Lambda, S3, EC2, CloudFormation',
    ],
  },
  {
    route: '$ /automation',
    title: 'Automation & RPA',
    description:
      'I analyze workflows and design automation that makes things simpler, built on experience spanning a wide range of industries.',
    bullets: [
      'UiPath Advanced Developer certified',
      '22 custom automation & analysis tools',
      '4 custom APIs built to tie systems together',
    ],
  },
  {
    route: '$ /ai-tooling',
    title: 'AI-Powered Tooling',
    description:
      'Practical AI that pays for itself: a Claude-based lead analysis system that filters junk leads automatically.',
    bullets: [
      'Claude vision reads text out of images',
      'Interacts with JavaScript to reveal hidden info',
      '+40% qualified leads',
    ],
  },
  {
    route: '$ /infrastructure',
    title: 'IT & Infrastructure',
    description:
      'Equally at home in systems work: server migrations, endpoint security, and deployments at serious scale.',
    bullets: [
      'Server & database migrations',
      '124,000-endpoint security rollout',
      '99% uptime for client web applications',
    ],
  },
];

const projects = [
  {
    title: 'AI-Powered Lead Analysis',
    tags: ['ai', 'automation', 'claude'],
    description:
      'The previous lead-scraping tool couldn’t see through junk leads. I built a Claude-powered analyzer for Dixon Golf and their brands that clicks through JavaScript buttons to reveal hidden information, uses vision to read text out of images, and throws out bad leads automatically, increasing qualified leads by about 40%.',
  },
  {
    title: 'Legacy Platform Modernization',
    tags: ['php 8.3', 'mysql/mariadb', 'it'],
    description:
      'An aging server on end-of-life software ran critical infrastructure for Dixon Golf and several sister companies. I migrated the database layer to a patched MySQL/MariaDB and moved every site from PHP 7.x to 8.3, cutting average page loads by up to 50% and taking queries that ran 24 to 30 seconds down to sub-second, a 30x improvement.',
  },
  {
    title: 'Git-Based Deployment Workflow',
    tags: ['git', 'devops', 'process'],
    description:
      'Thirteen legacy sites were edited directly on production over FTP, with no source control. I moved every site into its own Git repository, wired up webhooks that deploy to production on push, and trained a team new to Git on the day-to-day workflows they needed.',
  },
];
---

<BaseLayout
  title="Stuart Bingham | Full-Stack Developer & IT Professional"
  description="Full-stack developer and IT professional in Chandler, AZ. 15+ years building web platforms, automation, and infrastructure. Open to new opportunities."
>
  <!-- ============ HERO ============ -->
  <section class="px-4 py-11 sm:px-5 md:py-14 lg:py-20">
    <div class="mx-auto grid max-w-6xl items-center gap-10 lg:grid-cols-2 lg:gap-12">
      <div>
        <p class="flex items-center gap-2.5">
          <span class="relative flex h-2.5 w-2.5" aria-hidden="true">
            <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-success opacity-60"></span>
            <span class="relative inline-flex h-2.5 w-2.5 rounded-full bg-success"></span>
          </span>
          <span class="font-mono text-kicker font-bold uppercase tracking-(--tracking-kicker) text-text"><span aria-hidden="true">[ </span>STATUS: OPEN_TO_OPPORTUNITIES<span aria-hidden="true"> ]</span></span>
        </p>

        <h1 class="mt-6 text-hero font-bold tracking-(--tracking-heading)">Stuart Bingham</h1>

        <p class="lead mt-4 font-medium">
          Full-stack developer and IT professional. I analyze workflows and build automation that makes things simpler.
        </p>

        <ul class="mt-6 space-y-2 text-sm text-text-muted">
          <li><span class="font-mono text-accent-text" aria-hidden="true">&gt;</span> 15+ years across development, automation &amp; infrastructure</li>
          <li><span class="font-mono text-accent-text" aria-hidden="true">&gt;</span> Currently: Software Developer @ Dixon Golf</li>
          <li><span class="font-mono text-accent-text" aria-hidden="true">&gt;</span> Chandler, AZ &middot; open to remote &amp; relocation</li>
        </ul>

        <div class="mt-8 grid grid-cols-2 gap-3 sm:grid-cols-4">
          {stats.map((stat) => (
            <div class="stat-tile rounded-xl border border-border bg-inset p-4">
              <p class="text-2xl font-bold text-accent-hover">{stat.value}</p>
              <p class="mt-1 text-kicker font-medium uppercase tracking-(--tracking-kicker) text-text-muted">{stat.label}</p>
            </div>
          ))}
        </div>

        <div class="mt-8 flex flex-wrap items-center gap-3">
          <a
            href="/Stuart-Bingham-Resume.pdf"
            download
            class="btn-primary inline-flex items-center gap-2 rounded-lg bg-accent-600 px-6 py-3 text-sm font-bold uppercase tracking-(--tracking-kicker) text-white transition hover:bg-accent-700 hover:shadow-(--shadow-glow-sm) focus-visible:shadow-(--shadow-glow-sm)"
          >
            Download Resume
            <span class="party-new hidden party:inline-block" aria-hidden="true">NEW!!!</span>
          </a>
          <a
            href="/work/"
            class="inline-flex items-center rounded-lg border border-border bg-surface px-6 py-3 text-sm font-bold uppercase tracking-(--tracking-kicker) text-text transition hover:border-(--tint-accent-border-strong) hover:text-accent-text hover:shadow-(--shadow-glow-sm) focus-visible:shadow-(--shadow-glow-sm)"
          >
            View my work
          </a>
          <a
            href="https://www.linkedin.com/in/stuart-bingham-6267356a/"
            target="_blank"
            rel="noopener"
            class="inline-flex items-center rounded-lg border border-border bg-surface px-6 py-3 text-sm font-bold uppercase tracking-(--tracking-kicker) text-text transition hover:border-(--tint-accent-border-strong) hover:text-accent-text hover:shadow-(--shadow-glow-sm) focus-visible:shadow-(--shadow-glow-sm)"
          >
            LinkedIn<span class="sr-only"> (opens in new tab)</span>
          </a>
        </div>
      </div>

      <TerminalCard />
    </div>
  </section>

  <!-- ============ WHAT I DO ============ -->
  <section class="px-4 py-11 sm:px-5 md:py-14 lg:py-20" aria-labelledby="capabilities-heading">
    <div class="mx-auto max-w-6xl">
      <p class="kicker">Capabilities</p>
      <h2 id="capabilities-heading" class="mt-2">What I do</h2>
      <p class="lead mt-4">
        Fifteen-plus years across two skill sets: software development and IT infrastructure, with automation as the thread that ties them together.
      </p>

      <div class="mt-10 grid gap-6 lg:grid-cols-2">
        {capabilities.map((card) => (
          <div class="party-card rounded-xl border border-border bg-surface p-6 shadow-(--shadow-card) transition duration-200 hover:-translate-y-0.5 hover:border-(--tint-accent-border-strong) hover:shadow-(--shadow-glow)">
            <p class="mono-label text-text-muted">{card.route}</p>
            <h3 class="mt-2">{card.title}</h3>
            <p class="mt-2 text-text-muted">{card.description}</p>
            <ul class="mt-4 space-y-1.5">
              {card.bullets.map((bullet) => (
                <li class="flex gap-2 text-sm text-text-muted">
                  <span class="shrink-0 font-mono text-accent-text" aria-hidden="true">&rarr;</span> {bullet}
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ FEATURED WORK ============ -->
  <section class="px-4 py-11 sm:px-5 md:py-14 lg:py-20" aria-labelledby="work-heading">
    <div class="mx-auto max-w-6xl">
      <p class="kicker">Portfolio</p>
      <h2 id="work-heading" class="mt-2">Selected projects</h2>
      <p class="lead mt-4">
        Real problems, measurable results: a few recent highlights from ten case studies across development, automation, and IT.
      </p>

      <div class="mt-10 grid gap-6 lg:grid-cols-3">
        {projects.map((project) => (
          <article class="party-card flex flex-col rounded-xl border border-border bg-surface p-6 shadow-(--shadow-card) transition duration-200 hover:-translate-y-0.5 hover:border-(--tint-accent-border-strong) hover:shadow-(--shadow-glow)">
            <p class="mono-label text-text-muted">$ /work/</p>
            <h3 class="mt-2">{project.title}</h3>
            <ul class="mt-3 flex flex-wrap gap-x-3 gap-y-1">
              {project.tags.map((tag) => (
                <li class="mono-label text-accent-text">
                  <span aria-hidden="true">[ </span>{tag}<span aria-hidden="true"> ]</span>
                </li>
              ))}
            </ul>
            <p class="mt-3 flex-1 text-sm text-text-muted">{project.description}</p>
            <p class="mt-4">
              <a href="/work/" class="text-sm font-bold text-accent-text hover:underline">
                See all work <span aria-hidden="true">&rarr;</span>
              </a>
            </p>
          </article>
        ))}
      </div>

      <div class="mt-10 text-center">
        <a
          href="/work/"
          class="inline-flex items-center rounded-lg border border-border bg-surface px-6 py-3 text-sm font-bold uppercase tracking-(--tracking-kicker) text-text transition hover:border-(--tint-accent-border-strong) hover:text-accent-text hover:shadow-(--shadow-glow-sm) focus-visible:shadow-(--shadow-glow-sm)"
        >
          View all 10 projects
        </a>
      </div>
    </div>
  </section>

  <!-- ============ CONTACT CTA BAND ============ -->
  <section class="px-4 py-11 sm:px-5 md:py-14 lg:py-20" aria-labelledby="contact-heading">
    <div class="mx-auto max-w-6xl">
      <div class="rounded-2xl bg-primary px-6 py-12 text-center sm:px-10 lg:px-16 lg:py-16 dark:border dark:border-white/15">
        <p class="flex items-center justify-center gap-2.5">
          <span class="relative flex h-2.5 w-2.5" aria-hidden="true">
            <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-terminal-green opacity-60"></span>
            <span class="relative inline-flex h-2.5 w-2.5 rounded-full bg-terminal-green"></span>
          </span>
          <span class="font-mono text-kicker font-bold uppercase tracking-(--tracking-kicker) text-white"><span aria-hidden="true">[ </span>STATUS: AVAILABLE_FOR_HIRE<span aria-hidden="true"> ]</span></span>
        </p>

        <h2 id="contact-heading" class="mt-6 text-white">Want to discuss your next project?</h2>

        <p class="mx-auto mt-4 max-w-xl text-primary-100">
          Whether it&rsquo;s a role, a legacy platform that needs modernizing, or a workflow begging to be automated, I&rsquo;d like to hear about it.
        </p>

        <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
          <a
            href="mailto:bingham.stuart@gmail.com"
            class="btn-primary inline-flex items-center rounded-lg bg-white px-6 py-3 text-sm font-bold uppercase tracking-(--tracking-kicker) text-primary transition hover:bg-primary-100 hover:shadow-(--shadow-glow-sm) focus-visible:shadow-(--shadow-glow-sm)"
          >
            Email me
          </a>
          <a
            href="https://www.linkedin.com/in/stuart-bingham-6267356a/"
            target="_blank"
            rel="noopener"
            class="inline-flex items-center rounded-lg border border-white px-6 py-3 text-sm font-bold uppercase tracking-(--tracking-kicker) text-white transition hover:bg-white/10 hover:shadow-(--shadow-glow-sm) focus-visible:shadow-(--shadow-glow-sm)"
          >
            Connect on LinkedIn<span class="sr-only"> (opens in new tab)</span>
          </a>
        </div>

        <p class="mono-label mt-6 text-primary-200">response_time: usually &lt; 24h</p>
      </div>
    </div>
  </section>
</BaseLayout>
