---
// Party invite: after 90 seconds of cumulative time on the site (summed
// across pages and visits), ask once — ever — whether to enter party mode.
// Once the popup has been shown it never appears again, regardless of the
// answer. Time and the seen flag persist in localStorage.
---

<div
  id="party-invite"
  class="fixed inset-0 z-50 hidden items-center justify-center p-4"
  role="dialog"
  aria-modal="true"
  aria-labelledby="party-invite-title"
>
  <div class="absolute inset-0 bg-black/60" data-party-dismiss></div>
  <div
    class="relative w-full max-w-sm rounded-2xl border border-border bg-surface p-8 text-center shadow-(--shadow-card)"
  >
    <p class="mono-label font-bold text-accent-text" aria-hidden="true">[ INCOMING TRANSMISSION ]</p>
    <h2 id="party-invite-title" class="mt-3 text-h3 font-bold text-text">Do you want to party?</h2>
    <div class="mt-6 flex flex-col gap-3">
      <button
        type="button"
        data-party-yes
        class="btn-primary inline-flex items-center justify-center gap-2 rounded-lg bg-accent-600 px-6 py-3 text-sm font-bold uppercase tracking-(--tracking-kicker) text-white transition hover:bg-accent-700 hover:shadow-(--shadow-glow-sm) focus-visible:shadow-(--shadow-glow-sm)"
      >
        Enter Party Mode
      </button>
      <button
        type="button"
        data-party-dismiss
        class="inline-flex items-center justify-center rounded-lg border border-border bg-surface px-6 py-3 text-sm font-bold uppercase tracking-(--tracking-kicker) text-text transition hover:border-(--tint-accent-border-strong) hover:text-accent-text hover:shadow-(--shadow-glow-sm) focus-visible:shadow-(--shadow-glow-sm)"
      >
        No Thanks
      </button>
    </div>
  </div>
</div>

<script>
  const SEEN_KEY = 'party-invite-seen';
  const TIME_KEY = 'party-invite-seconds';
  const THRESHOLD_SECONDS = 90;

  const root = document.getElementById('party-invite');

  function storageGet(key: string): string | null {
    try {
      return localStorage.getItem(key);
    } catch {
      return null;
    }
  }

  function storageSet(key: string, value: string) {
    try {
      localStorage.setItem(key, value);
    } catch {
      /* storage unavailable: the invite just won't persist across pages */
    }
  }

  function close() {
    root?.classList.add('hidden');
    root?.classList.remove('flex');
  }

  function show() {
    if (!root) return;
    // Mark seen the moment it appears — it only ever triggers once.
    storageSet(SEEN_KEY, '1');
    root.classList.remove('hidden');
    root.classList.add('flex');
    root.querySelector<HTMLButtonElement>('[data-party-yes]')?.focus();
  }

  function enterParty() {
    const w = window as unknown as { __setTheme?: (t: string) => void };
    if (typeof w.__setTheme === 'function') {
      // Header owns theme state (persists choice + confetti on party entry)
      w.__setTheme('party');
    } else {
      document.documentElement.dataset.theme = 'party';
      storageSet('theme', 'party');
    }
    close();
  }

  function init() {
    if (!root || storageGet(SEEN_KEY)) return;
    // Already partying? No need to ask.
    if (document.documentElement.dataset.theme === 'party') {
      storageSet(SEEN_KEY, '1');
      return;
    }

    root.querySelector('[data-party-yes]')?.addEventListener('click', enterParty);
    root.querySelectorAll('[data-party-dismiss]').forEach((el) => el.addEventListener('click', close));
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !root.classList.contains('hidden')) close();
    });

    let elapsed = parseInt(storageGet(TIME_KEY) ?? '0', 10) || 0;
    const timer = window.setInterval(() => {
      if (document.visibilityState !== 'visible') return;
      elapsed += 1;
      storageSet(TIME_KEY, String(elapsed));
      if (elapsed >= THRESHOLD_SECONDS) {
        window.clearInterval(timer);
        show();
      }
    }, 1000);
  }

  init();
</script>
