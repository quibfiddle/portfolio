---
// component-builder: TerminalCard
// Purpose: Ubuntu-terminal hero card rendering a `const developer = {...}` object
// Yaru-style chrome: title centered, window controls on the RIGHT (not macOS traffic lights)
---

<figure
  class="overflow-hidden rounded-lg shadow-(--shadow-card)"
  aria-label="Interactive Ubuntu terminal describing Stuart Bingham. Type help for commands."
  data-terminal-card
>
  <!-- Title bar -->
  <div class="relative flex h-9 items-center justify-center bg-terminal-chrome px-3">
    <span class="font-mono text-xs text-terminal-muted">stuart@stuartbingham: ~</span>
    <div class="term-controls absolute right-3 flex items-center gap-1.5" aria-hidden="true">
      <div class="flex h-4 w-4 items-center justify-center rounded-full bg-(--tint-terminal-well) text-[10px] leading-none text-terminal-muted">&ndash;</div>
      <div class="flex h-4 w-4 items-center justify-center rounded-full bg-(--tint-terminal-well) text-[8px] leading-none text-terminal-muted">&#9633;</div>
      <div class="flex h-4 w-4 items-center justify-center rounded-full bg-accent text-[10px] leading-none text-white">&times;</div>
    </div>
  </div>

  <!-- Terminal body -->
  <div class="max-h-[70vh] overflow-y-auto bg-terminal p-5 font-mono text-sm leading-relaxed sm:p-6" data-term-body>
    <div>
      <span class="text-terminal-green">stuart@stuartbingham</span><span class="text-terminal-muted">:</span><span class="text-terminal-text">~</span><span class="text-terminal-muted">$</span>
      <span class="text-terminal-text" data-term-cmd>cat developer.js</span>
    </div>

    <div class="mt-3 text-terminal-text" data-term-line>
      const <span class="text-terminal-green">developer</span> <span class="text-terminal-muted">=</span> <span class="text-terminal-muted">&lbrace;</span>
    </div>
    <div class="pl-5" data-term-line><span class="text-terminal-green">name</span><span class="text-terminal-muted">:</span> <span class="text-terminal-orange">'Stuart Bingham'</span><span class="text-terminal-muted">,</span></div>
    <div class="pl-5" data-term-line><span class="text-terminal-green">role</span><span class="text-terminal-muted">:</span> <span class="text-terminal-orange">'Full-Stack Developer'</span><span class="text-terminal-muted">,</span></div>
    <div class="pl-5" data-term-line><span class="text-terminal-green">alsoAnswersTo</span><span class="text-terminal-muted">:</span> <span class="text-terminal-orange">'IT Professional'</span><span class="text-terminal-muted">,</span></div>
    <div class="pl-5" data-term-line><span class="text-terminal-green">experience</span><span class="text-terminal-muted">:</span> <span class="text-terminal-orange">'15+ years'</span><span class="text-terminal-muted">,</span></div>
    <div class="pl-5" data-term-line><span class="text-terminal-green">location</span><span class="text-terminal-muted">:</span> <span class="text-terminal-orange">'Chandler, AZ'</span><span class="text-terminal-muted">,</span></div>
    <div class="pl-5" data-term-line><span class="text-terminal-green">stack</span><span class="text-terminal-muted">:</span> <span class="text-terminal-muted">[</span><span class="text-terminal-orange">'JavaScript/TS'</span><span class="text-terminal-muted">,</span> <span class="text-terminal-orange">'PHP'</span><span class="text-terminal-muted">,</span> <span class="text-terminal-orange">'Python'</span><span class="text-terminal-muted">,</span> <span class="text-terminal-orange">'AWS'</span><span class="text-terminal-muted">],</span></div>
    <div class="pl-5" data-term-line><span class="text-terminal-green">passion</span><span class="text-terminal-muted">:</span> <span class="text-terminal-orange">'automating the boring stuff'</span><span class="text-terminal-muted">,</span></div>
    <div class="pl-5" data-term-line><span class="text-terminal-green">status</span><span class="text-terminal-muted">:</span> <span class="text-terminal-orange">'open_to_opportunities'</span><span class="text-terminal-muted">,</span> <span class="text-terminal-muted">// &larr; that's you!</span></div>
    <div class="text-terminal-muted" data-term-line>&rbrace;;</div>

    <!-- Party-mode bonus output (display:none outside party theme) -->
    <div class="mt-3 hidden party:block" data-term-line aria-hidden="true">
      <div>
        <span class="text-terminal-green">stuart@stuartbingham</span><span class="text-terminal-muted">:</span><span class="text-terminal-text">~</span><span class="text-terminal-muted">$</span>
        <span class="text-terminal-text">./party.sh</span>
      </div>
      <div><span class="text-terminal-green">[OK]</span> <span class="text-terminal-text">vibes loaded</span></div>
      <div><span class="text-terminal-green">[OK]</span> <span class="text-terminal-text">disco daemon started</span></div>
    </div>

    <div class="mt-3" data-term-final>
      <span class="text-terminal-green">stuart@stuartbingham</span><span class="text-terminal-muted">:</span><span class="text-terminal-text">~</span><span class="text-terminal-muted">$</span><span class="terminal-cursor" aria-hidden="true"></span>
    </div>
  </div>
</figure>

<!-- Typewriter animation. Inline so it runs during parse (no flash of hidden content).
     No-JS visitors see the full card; reduced-motion users skip straight to it. -->
<script is:inline>
  (function () {
    var card = document.querySelector('[data-terminal-card]');
    if (!card) return;
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    var cmd = card.querySelector('[data-term-cmd]');
    var lines = card.querySelectorAll('[data-term-line]');
    var finalLine = card.querySelector('[data-term-final]');
    if (!cmd || !finalLine) return;

    var text = cmd.textContent;
    cmd.textContent = '';
    for (var j = 0; j < lines.length; j++) lines[j].style.visibility = 'hidden';
    finalLine.style.visibility = 'hidden';

    var i = 0;
    function typeChar() {
      if (i < text.length) {
        cmd.textContent += text.charAt(i);
        i += 1;
        setTimeout(typeChar, 50);
      } else {
        setTimeout(function () { revealLine(0); }, 150);
      }
    }

    function revealLine(n) {
      if (n < lines.length) {
        lines[n].style.visibility = '';
        setTimeout(function () { revealLine(n + 1); }, 80);
      } else {
        finalLine.style.visibility = '';
        card.dataset.introDone = 'true';
        card.dispatchEvent(new CustomEvent('terminal-intro-done'));
      }
    }

    setTimeout(typeChar, 300);
  })();
</script>

<!-- Interactive command line: activates once the intro finishes (immediately
     for reduced-motion visitors). Never autofocuses. -->
<script>
  import { initTerminal } from '../scripts/terminal';

  const card = document.querySelector<HTMLElement>('[data-terminal-card]');
  if (card) {
    const term = initTerminal(card);
    const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (reducedMotion || card.dataset.introDone === 'true') {
      term.activate();
    } else {
      card.addEventListener('terminal-intro-done', () => term.activate(), { once: true });
    }
  }
</script>

<style>
  .terminal-cursor {
    display: inline-block;
    width: 0.6em;
    height: 1.1em;
    margin-left: 0.4em;
    vertical-align: text-bottom;
    background-color: var(--color-terminal-text);
    animation: terminal-blink 1.1s steps(1) infinite;
  }

  @keyframes terminal-blink {
    50% {
      opacity: 0;
    }
  }
</style>
