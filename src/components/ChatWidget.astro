---
// component-builder: ChatWidget
// Purpose: "Chat with me" terminal window. Live-chat-with-Stuart flow with an
// AI-persona fallback when he's away. Backend intentionally stubbed:
// DEMO_MODE in the script fakes all four endpoints so the full flow is
// clickable for design review. Integration guide: docs/chat-widget.md
---

<div class="fixed bottom-4 right-4 z-50 flex flex-col items-end gap-3 sm:bottom-6 sm:right-6">
  <!-- Chat window -->
  <section
    id="chat-window"
    role="dialog"
    aria-modal="false"
    aria-label="Chat with Stuart"
    class="hidden w-[calc(100vw-2rem)] max-w-sm overflow-hidden rounded-lg shadow-(--shadow-card-hover)"
  >
    <!-- Ubuntu terminal chrome (matches TerminalCard: controls on the RIGHT) -->
    <div class="relative flex h-9 items-center justify-center bg-terminal-chrome px-3">
      <p class="font-mono text-xs text-terminal-muted">guest@stuartbingham: ~/chat</p>
      <div class="absolute right-3 flex items-center gap-1.5">
        <span class="h-3.5 w-3.5 rounded-full bg-white/20" aria-hidden="true"></span>
        <span class="h-3.5 w-3.5 rounded-full bg-white/20" aria-hidden="true"></span>
        <button
          type="button"
          id="chat-close"
          class="flex h-3.5 w-3.5 items-center justify-center rounded-full bg-accent text-[9px] font-bold leading-none text-white"
          aria-label="Close chat"
        >&times;</button>
      </div>
    </div>

    <div class="flex max-h-[70vh] flex-col bg-terminal">
      <!-- Message log -->
      <div
        id="chat-log"
        class="min-h-40 flex-1 space-y-3 overflow-y-auto p-4 font-mono text-sm text-terminal-text"
        aria-live="polite"
      >
        <p>
          <span class="text-terminal-green">stuart@stuartbingham</span><span class="text-terminal-muted">:~$</span>
          Hi! Leave me a message and my phone gets a text. If I'm at a keyboard, we can chat right here.
        </p>
      </div>

      <!-- Composer -->
      <form id="chat-form" class="space-y-2 border-t border-(--tint-terminal-border) p-3">
        <input
          type="text"
          id="chat-name"
          name="name"
          required
          maxlength="80"
          placeholder="your name"
          autocomplete="name"
          class="w-full rounded-md border border-(--tint-terminal-border) bg-(--tint-terminal-well) px-3 py-2 font-mono text-sm text-terminal-text placeholder:text-terminal-muted"
        />
        <div class="flex items-end gap-2">
          <label for="chat-input" class="sr-only">Message</label>
          <textarea
            id="chat-input"
            name="message"
            required
            maxlength="1000"
            rows="2"
            placeholder="type a message..."
            class="w-full flex-1 resize-none rounded-md border border-(--tint-terminal-border) bg-(--tint-terminal-well) px-3 py-2 font-mono text-sm text-terminal-text placeholder:text-terminal-muted"
          ></textarea>
          <button
            type="submit"
            id="chat-send"
            class="rounded-lg bg-accent-600 px-4 py-2 font-mono text-sm font-bold text-white transition-colors hover:bg-accent-700"
          >send</button>
        </div>
        <p id="chat-hint" class="font-mono text-xs text-terminal-muted">sends a text to Stuart's phone</p>
      </form>
    </div>
  </section>

  <!-- Floating launcher -->
  <button
    type="button"
    id="chat-launcher"
    aria-expanded="false"
    aria-controls="chat-window"
    class="flex items-center gap-2 rounded-lg bg-accent-600 px-4 py-3 font-mono text-sm font-bold text-white shadow-(--shadow-card) transition-colors hover:bg-accent-700"
  >
    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <polyline points="4 17 10 11 4 5"/><line x1="12" y1="19" x2="20" y2="19"/>
    </svg>
    chat
  </button>
</div>

<script>
  // ============================================================
  // Config — see docs/chat-widget.md for the backend contract.
  // Backend: Cloudflare Worker (worker/index.ts) relays to Stuart's Telegram.
  // ============================================================
  const ENDPOINTS = {
    session: '/api/chat/session',
    send: '/api/chat/send',
    poll: '/api/chat/poll',
    ai: '/api/chat/ai',
  };
  const LIVE_WAIT_SECONDS = 90;
  const POLL_INTERVAL_MS = 3000;
  // sessionStorage (this tab only) so the conversation follows the visitor
  // across pages, but a fresh visit tomorrow starts a fresh chat.
  const STORE_KEY = 'chat-state';

  const launcher = document.getElementById('chat-launcher') as HTMLButtonElement;
  const windowEl = document.getElementById('chat-window') as HTMLElement;
  const closeBtn = document.getElementById('chat-close') as HTMLButtonElement;
  const log = document.getElementById('chat-log') as HTMLElement;
  const form = document.getElementById('chat-form') as HTMLFormElement;
  const nameInput = document.getElementById('chat-name') as HTMLInputElement;
  const msgInput = document.getElementById('chat-input') as HTMLTextAreaElement;
  const hint = document.getElementById('chat-hint') as HTMLElement;

  type Mode = 'compose' | 'waiting' | 'live' | 'ai-offer' | 'ai';
  let mode: Mode = 'compose';
  let sessionId: string | null = null;
  let aiHistory: { role: string; content: string }[] = [];
  let deliveredCount = 0;
  let awayTimer: ReturnType<typeof setTimeout> | null = null;
  let pollTimer: ReturnType<typeof setInterval> | null = null;

  const PROMPTS: Record<string, { name: string; cls: string }> = {
    visitor: { name: 'you@guest', cls: 'text-terminal-orange' },
    stuart: { name: 'stuart@stuartbingham', cls: 'text-terminal-green' },
    ai: { name: 'ai@stuartbingham', cls: 'text-terminal-muted' },
    system: { name: '', cls: '' },
  };

  // Persisted so the conversation survives page navigation.
  let transcript: { from: keyof typeof PROMPTS; text: string }[] = [];
  let chatOpen = false;
  let ended = false;
  let offerDeadline: number | null = null;

  function saveState() {
    try {
      sessionStorage.setItem(
        STORE_KEY,
        JSON.stringify({ mode, sessionId, aiHistory, deliveredCount, transcript, chatOpen, ended, offerDeadline })
      );
    } catch {
      /* storage unavailable: chat still works, it just won't follow across pages */
    }
  }

  function addLine(from: keyof typeof PROMPTS, text: string, opts: { transient?: boolean; replay?: boolean } = {}) {
    const p = document.createElement('p');
    if (from === 'system') {
      p.className = 'text-terminal-muted';
      p.textContent = text;
    } else {
      const prompt = PROMPTS[from];
      const promptSpan = document.createElement('span');
      promptSpan.className = prompt.cls;
      promptSpan.textContent = prompt.name;
      const sep = document.createElement('span');
      sep.className = 'text-terminal-muted';
      sep.textContent = ':~$ ';
      p.append(promptSpan, sep, document.createTextNode(text));
    }
    log.appendChild(p);
    log.scrollTop = log.scrollHeight;
    if (!opts.transient && !opts.replay) {
      transcript.push({ from, text });
      saveState();
    }
    return p;
  }

  function addAction(label: string, onClick: () => void) {
    const wrap = document.createElement('p');
    const btn = document.createElement('button');
    btn.type = 'button';
    btn.className =
      'rounded-lg border border-(--tint-terminal-border) px-3 py-1.5 font-mono text-sm text-terminal-orange transition-colors hover:bg-(--tint-terminal-well)';
    btn.textContent = label;
    btn.addEventListener('click', () => {
      wrap.remove();
      onClick();
    });
    wrap.appendChild(btn);
    log.appendChild(wrap);
    log.scrollTop = log.scrollHeight;
  }

  function openChat(focus = true) {
    windowEl.classList.remove('hidden');
    launcher.setAttribute('aria-expanded', 'true');
    chatOpen = true;
    saveState();
    if (focus) (mode === 'compose' ? nameInput : msgInput).focus();
  }
  function closeChat() {
    windowEl.classList.add('hidden');
    launcher.setAttribute('aria-expanded', 'false');
    chatOpen = false;
    saveState();
    launcher.focus();
  }
  launcher.addEventListener('click', () => {
    windowEl.classList.contains('hidden') ? openChat() : closeChat();
  });
  closeBtn.addEventListener('click', closeChat);
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && !windowEl.classList.contains('hidden')) closeChat();
  });

  // ============================================================
  // Backend adapters
  // ============================================================
  async function apiCreateSession(name: string, message: string) {
    const res = await fetch(ENDPOINTS.session, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ name, message }),
    });
    return res.json();
  }

  async function apiSendLive(message: string) {
    await fetch(ENDPOINTS.send, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ sessionId, message }),
    });
  }

  async function apiAskAI(message: string): Promise<string> {
    aiHistory.push({ role: 'user', content: message });
    const res = await fetch(ENDPOINTS.ai, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ sessionId, messages: aiHistory }),
    });
    const data = await res.json();
    aiHistory.push({ role: 'assistant', content: data.reply });
    saveState();
    return data.reply;
  }

  // ============================================================
  // Polling — runs for the life of the chat once a session exists, so
  // Stuart's Telegram replies keep arriving whether we're still waiting
  // on his first reply or already live.
  // ============================================================
  function goLive() {
    if (mode === 'live') return;
    if (mode === 'ai' || mode === 'ai-offer') addLine('system', 'stuart is here now.');
    if (awayTimer) {
      clearTimeout(awayTimer);
      awayTimer = null;
    }
    mode = 'live';
    hint.textContent = 'you are chatting live with Stuart';
    saveState();
  }

  async function pollOnce() {
    if (!sessionId) return;
    try {
      const res = await fetch(`${ENDPOINTS.poll}?sessionId=${sessionId}&after=${deliveredCount}`);
      const data = await res.json();
      const newMessages = data.newMessages ?? [];
      if (newMessages.length > 0) {
        for (const m of newMessages) addLine('stuart', m.text);
        deliveredCount += newMessages.length;
        saveState();
      }
      if (newMessages.length > 0 || data.status === 'live') goLive();
    } catch {
      // Transient network error — the next tick retries.
    }
  }

  function startPolling() {
    if (pollTimer) return;
    pollTimer = setInterval(pollOnce, POLL_INTERVAL_MS);
  }

  // ============================================================
  // Flow
  // ============================================================
  function disableComposer() {
    form.querySelectorAll('input, textarea, button').forEach((el) => ((el as HTMLInputElement).disabled = true));
  }

  function enterAIMode() {
    if (mode === 'live') return;
    mode = 'ai';
    hint.textContent = 'AI responses are generated. For the real Stuart, use the Contact page.';
    addLine('ai', "[AI] Hi, I'm an assistant that knows Stuart's work. What would you like to know?");
    msgInput.focus();
  }

  function addAIOfferActions() {
    addAction('[ start AI chat ]', enterAIMode);
    addAction('[ no thanks, he can text back ]', () => {
      ended = true;
      addLine('system', "done. he'll follow up when he's back at a keyboard.");
      disableComposer();
    });
  }

  function offerAI() {
    if (mode !== 'waiting') return;
    mode = 'ai-offer';
    addLine('system', 'stuart is away_from_keyboard. your message reached his phone.');
    addLine('system', 'in the meantime, want to ask an AI about his experience?');
    addAIOfferActions();
    saveState();
  }

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const message = msgInput.value.trim();
    if (!message) return;

    if (mode === 'compose') {
      const name = nameInput.value.trim();
      if (!name) return;
      addLine('visitor', message);
      msgInput.value = '';
      nameInput.classList.add('hidden');
      const status = addLine('system', 'sending... [texting stuart]', { transient: true });
      const session = await apiCreateSession(name, message);
      sessionId = session.sessionId;
      status.remove();
      addLine('system', 'delivered. waiting to see if stuart is around...');
      mode = 'waiting';
      offerDeadline = Date.now() + LIVE_WAIT_SECONDS * 1000;
      hint.textContent = "you can keep typing, he'll get it all";
      saveState();
      startPolling();
      awayTimer = setTimeout(offerAI, LIVE_WAIT_SECONDS * 1000);
      return;
    }

    addLine('visitor', message);
    msgInput.value = '';

    if (mode === 'ai') {
      const thinking = addLine('system', '...', { transient: true });
      const reply = await apiAskAI(message);
      thinking.remove();
      addLine('ai', `[AI] ${reply}`);
    } else {
      await apiSendLive(message);
    }
  });

  // ============================================================
  // Restore — rebuild the conversation this tab already started, so
  // navigating between pages doesn't reset the chat.
  // ============================================================
  function restore() {
    let saved: any = null;
    try {
      saved = JSON.parse(sessionStorage.getItem(STORE_KEY) ?? 'null');
    } catch {
      return;
    }
    if (!saved || typeof saved !== 'object') return;

    mode = saved.mode ?? 'compose';
    sessionId = saved.sessionId ?? null;
    aiHistory = Array.isArray(saved.aiHistory) ? saved.aiHistory : [];
    deliveredCount = saved.deliveredCount ?? 0;
    transcript = Array.isArray(saved.transcript) ? saved.transcript : [];
    chatOpen = !!saved.chatOpen;
    ended = !!saved.ended;
    offerDeadline = saved.offerDeadline ?? null;

    for (const line of transcript) addLine(line.from, line.text, { replay: true });

    if (mode !== 'compose') {
      // Name was collected when the session was created; the hidden,
      // now-empty input must not block later submits.
      nameInput.classList.add('hidden');
      nameInput.required = false;
    }

    if (mode === 'waiting') {
      hint.textContent = "you can keep typing, he'll get it all";
      const remaining = (offerDeadline ?? 0) - Date.now();
      if (remaining <= 0) offerAI();
      else awayTimer = setTimeout(offerAI, remaining);
    } else if (mode === 'ai-offer' && !ended) {
      addAIOfferActions();
    } else if (mode === 'ai') {
      hint.textContent = 'AI responses are generated. For the real Stuart, use the Contact page.';
    } else if (mode === 'live') {
      hint.textContent = 'you are chatting live with Stuart';
    }

    if (ended) disableComposer();
    if (sessionId) startPolling();
    if (chatOpen) openChat(false);
  }

  restore();
</script>
